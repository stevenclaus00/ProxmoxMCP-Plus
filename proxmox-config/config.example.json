{
    "proxmox": {
        "host": "your-proxmox-host-ip",
        "port": 8006,
        "verify_ssl": true,
        "service": "PVE"
    },
    "api_tunnel": {
        "enabled": false,
        "ssh_host": "your-ssh-alias",
        "local_host": "127.0.0.1",
        "local_port": 8006,
        "remote_host": "127.0.0.1",
        "remote_port": 8006,
        "connect_timeout": 15
    },
    "auth": {
        "user": "username@pve",
        "token_name": "your-token-name",
        "token_value": "your-token-value"
    },
    "logging": {
        "level": "DEBUG",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        "file": "proxmox_mcp.log"
    },
    "mcp": {
        "host": "127.0.0.1",
        "port": 8000,
        "transport": "STDIO",
        "dns_rebinding_protection": null,
        "allowed_hosts": [],
        "allowed_origins": []
    },
    "security": {
        "dev_mode": false
    },
    "jobs": {
        "sqlite_path": "proxmox-jobs.sqlite3"
    },
    "command_policy": {
        "mode": "deny_all",
        "allow_patterns": [],
        "deny_patterns": [
            "(^|\\s)rm\\s+-rf(\\s|$)",
            ":\\(\\)\\{:\\|:\\&\\};:"
        ],
        "require_approval_token": false,
        "approval_token": null
    },
    "ssh": {
        "user": "mcp-agent",
        "port": 22,
        "key_file": "~/.ssh/proxmox_key",
        "use_sudo": true,
        "known_hosts_file": "~/.ssh/known_hosts",
        "host_overrides": {
            "pve": "your-proxmox-node-ip-or-ssh-alias"
        },
        "strict_host_key_checking": true,
        "prefer_ssh_client": false
    }
}
